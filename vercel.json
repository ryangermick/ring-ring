{
  "rewrites": [
    { "source": "/history", "destination": "/index.html" },
    { "source": "/characters", "destination": "/index.html" },
    { "source": "/characters/:slug", "destination": "/index.html" },
    { "source": "/profile", "destination": "/index.html" },
    { "source": "/settings", "destination": "/index.html" },
    { "source": "/login", "destination": "/index.html" },
    { "source": "/call", "destination": "/index.html" },
    { "source": "/transcript", "destination": "/index.html" },
    { "source": "/about", "destination": "/index.html" },
    { "source": "/voice-test", "destination": "/index.html" },
    { "source": "/:slug", "destination": "/api/share?id=:slug" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(self), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.supabase.co https://*.googleusercontent.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co wss://generativelanguage.googleapis.com https://accounts.google.com; frame-src https://accounts.google.com; media-src 'self' blob:"
        }
      ]
    }
  ]
}
